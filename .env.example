# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Database Configuration
# PostgreSQL: postgres://user:password@host:port/database?sslmode=require
# SQLite: ./data/accounts.db
DATABASE_URL=postgres://user:password@localhost:5432/webmail?sslmode=require

# Security (Required - must be 32 bytes raw or 64 hex characters)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here
WEBHOOK_SECRET=your-webhook-secret-key
SIGNED_URL_SECRET=your-signed-url-secret

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
