{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "cwd": "${workspaceFolder}/webmail_engine",
            "program": "${workspaceFolder}/webmail_engine/cmd/main.go",
            "args": [
                "-config",
                "config.json",
                "-dev"
            ]
        },
        {
            "name": "Debug Test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${activeEditor}"
        },
        {
            "name": "Debug Main",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "cwd": "${workspaceFolder}/webmail_engine",
            "program": "${workspaceFolder}/webmail_engine/cmd/main.go",
            "args": [
                "-config",
                "config.json",
                "-dev"
            ]
        },
        {
            "name": "Vite Server",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/webmail_engine/frontend",
            "runtimeExecutable": "bun",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "ready in (\\d+) ms",
                "uriFormat": "http://localhost:5173",
                "action": "openExternally"
            }
        },
        {
            "name": "Debug Frontend (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/webmail_engine/frontend/src",
            "runtimeArgs": [
                "--remote-debugging-port=9222"
            ]
        },
        {
            "name": "Full Stack (Go + Vite)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/webmail_engine/frontend",
            "runtimeExecutable": "bun",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "preLaunchTask": "start-go-server"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack Debug",
            "configurations": [
                "Debug Main",
                "Debug Frontend (Chrome)"
            ],
            "presentation": {
                "hidden": false,
                "group": "fullstack",
                "order": 1
            }
        }
    ]
}