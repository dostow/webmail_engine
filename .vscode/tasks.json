{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start-go-server",
            "type": "shell",
            "command": "go",
            "args": [
                "run",
                "cmd/main.go",
                "-config",
                "config.json",
                "-dev"
            ],
            "cwd": "${workspaceFolder}/webmail_engine",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*server started.*",
                    "endsPattern": ".*server started.*"
                }
            }
        }
    ]
}
