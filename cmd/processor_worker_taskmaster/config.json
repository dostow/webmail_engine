{
  "worker_type": "processor",
  "worker_id": "processor-worker-1",
  "dispatch": {
    "type": "${DISPATCH_TYPE:-managed}",
    "addr": "${REST_ADDR:-:8081}",
    "redis_url": "${REDIS_URL:-redis://localhost:6379}",
    "queue_name": "${QUEUE_NAME:-webmail_processor_tasks}"
  },
  "execution": {
    "mode": "${EXECUTION_MODE:-managed}",
    "worker_count": 4,
    "task_timeout": 120000000000,
    "queue_size": 40,
    "redis_url": "${REDIS_URL:-redis://localhost:6379}",
    "result_backend": "${RESULT_BACKEND:-redis://localhost:6379}"
  },
  "scheduler": {
    "enabled": false,
    "schedule_accounts": false
  },
  "shutdown_timeout": 30000000000,
  "queue": {
    "type": "memory",
    "redis_url": "${REDIS_URL:-redis://localhost:6379}"
  },
  "store": {
    "type": "sql",
    "sql": {
      "driver": "${DB_DRIVER:-sqlite}",
      "dsn": "${DATABASE_URL:-./data/webmail.db}",
      "max_connections": 10,
      "min_idle": 2,
      "busy_timeout_ms": 5000
    }
  },
  "logging": {
    "level": "${LOG_LEVEL:-info}",
    "format": "${LOG_FORMAT:-text}"
  },
  "webhook": {
    "url": "${WEBHOOK_URL:-}",
    "secret_key": "${WEBHOOK_SECRET:-}",
    "enabled": false
  }
}
