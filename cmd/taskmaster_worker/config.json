{
  "worker_type": "taskmaster",
  "worker_id": "taskmaster-worker-1",
  "operational_mode": "managed",
  "shutdown_timeout": 30000000000,
  "queue": {
    "type": "memory",
    "redis_url": "${REDIS_URL:-redis://localhost:6379}"
  },
  "logging": {
    "level": "${LOG_LEVEL:-info}",
    "format": "${LOG_FORMAT:-text}"
  },
  "webhook": {
    "url": "${WEBHOOK_URL:-}",
    "secret_key": "${WEBHOOK_SECRET:-}",
    "enabled": "${WEBHOOK_ENABLED:-false}"
  }
}
