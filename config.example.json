{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "read_timeout": "30s",
    "write_timeout": "30s",
    "idle_timeout": "120s",
    "shutdown_timeout": "30s",
    "tls_enabled": false,
    "tls_cert_file": "",
    "tls_key_file": ""
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0,
    "pool_size": 10,
    "min_idle_conns": 5,
    "conn_timeout": "10s",
    "read_timeout": "3s",
    "write_timeout": "3s",
    "max_retries": 3
  },
  "pool": {
    "max_connections": 100,
    "idle_timeout": "5m",
    "dial_timeout": "30s",
    "cleanup_interval": "1m"
  },
  "scheduler": {
    "enabled": true,
    "default_bucket_size": 100,
    "default_refill_rate": 10,
    "operation_costs": {
      "FETCH": 1,
      "SEARCH": 5,
      "SEND": 3,
      "LIST": 1,
      "RETRIEVE": 2,
      "ATTACHMENT": 3,
      "IDLE": 0,
      "SYNC": 2
    },
    "queue_size": 1000,
    "max_queue_wait": "30m"
  },
  "security": {
    "encryption_key": "",
    "webhook_secret": "",
    "signed_url_secret": "",
    "signed_url_expiry": "24h",
    "max_attachment_size": 52428800,
    "allowed_origins": [],
    "rate_limit_enabled": true,
    "rate_limit_requests": 100,
    "rate_limit_window": "1m"
  },
  "storage": {
    "temp_path": "./temp",
    "attachment_path": "./temp/attachments",
    "max_temp_size": 1073741824,
    "cleanup_interval": "1h",
    "attachment_expiry": "24h"
  },
  "webhook": {
    "enabled": true,
    "max_retries": 3,
    "retry_backoff": "1m",
    "timeout": "30s",
    "event_retention": "24h",
    "cleanup_interval": "1h"
  },
  "logging": {
    "level": "info",
    "format": "text",
    "output_path": "stdout",
    "enable_json": false
  }
}
